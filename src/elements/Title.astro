---
/**
 * Title component following the Bulma title spec.
 * https://bulma.io/documentation/elements/title/
 */
type Props = {
  /** Size modifier, 1 (largest) to 6 (smallest) */
  size?: 1 | 2 | 3 | 4 | 5 | 6;
  /** HTML tag to render, defaults to h1 */
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "p";
  /** .is-spaced — keeps the space below when followed by a subtitle */
  spaced?: boolean;
  class?: string;
  [key: string]: unknown;
};

const { size, as: Tag = "h1", spaced, class: className, ...rest } = Astro.props;

const classes = [
  "title",
  size && `is-${size}`,
  spaced && "is-spaced",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<Tag class={classes} {...rest}><slot /></Tag>
