---
/**
 * Radio component following the Bulma radio spec.
 * https://bulma.io/documentation/form/radio/
 *
 * Radios sharing a name form a group; wrap them in a .control or a Field.
 *
 * Usage (with label prop):
 *   <Radio name="rsvp" value="yes" label="Going" checked />
 *   <Radio name="rsvp" value="no" label="Not going" />
 *
 * Usage (with rich slot content):
 *   <Radio name="plan" value="pro"><strong>Pro</strong> — $10/month</Radio>
 */

interface Props {
  /** input name attribute; radios with the same name form a group (required) */
  name: string;
  /** value attribute (required — distinguishes radios in a group) */
  value: string;
  /** input id; defaults to `${name}-${value}` */
  id?: string;
  /** Label text shown next to the radio */
  label?: string;
  /** Whether the radio is checked */
  checked?: boolean;
  /** Whether the field is required */
  required?: boolean;
  /** Whether the radio is disabled */
  disabled?: boolean;
  /** Extra classes on the wrapping <label> */
  class?: string;
  /** Any other native input attributes passed through to <input> */
  [key: string]: unknown;
}

const {
  name,
  value,
  id = `${name}-${value}`,
  label,
  checked,
  required,
  disabled,
  class: className,
  ...rest
} = Astro.props;

// data-* and aria-* attrs belong on the label (the selectable element),
// not the inner input, so JS like radio.getAttribute("data-user-id") works.
const labelAttrs: Record<string, unknown> = {};
const inputAttrs: Record<string, unknown> = {};
for (const [k, v] of Object.entries(rest)) {
  if (k.startsWith("data-") || k.startsWith("aria-")) {
    labelAttrs[k] = v;
  } else {
    inputAttrs[k] = v;
  }
}
---

<label class:list={["radio", className]} {...labelAttrs}>
  <input
    type="radio"
    {name}
    {id}
    {value}
    {checked}
    {required}
    {disabled}
    {...inputAttrs}
  />
  {label ?? <slot />}
</label>
