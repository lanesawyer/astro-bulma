---
import Notification from "../elements/Notification.astro";

interface Props {
  pageTitle: string;
  pageSubtitle?: string;
  message?: string;
  messageType?: "link" | "primary" | "info" | "success" | "warning" | "danger";
}

const { pageTitle, pageSubtitle, message, messageType = "success" } = Astro.props;
---

<slot name="before" />

<div class="level mb-4">
  <div class="level-left">
    <div class="level-item">
      <div>
        <h1 class="title">{pageTitle}</h1>
        {pageSubtitle && <p class="subtitle">{pageSubtitle}</p>}
      </div>
    </div>
  </div>
  <div class="level-right">
    <div class="level-item">
      <slot name="action" />
    </div>
  </div>
</div>

{
  message && (
    <Notification color={messageType} light class="mb-4">
      {message}
    </Notification>
  )
}

<slot />
<slot name="modals" />
