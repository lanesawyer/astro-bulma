---
/**
 * Light/dark mode toggle backed by Bulma 1.0's native `data-theme` support.
 * https://bulma.io/documentation/features/dark-mode/
 *
 * Sets `data-theme` on <html>, persists the choice in localStorage ("theme"),
 * and follows the system preference until the user picks a theme explicitly.
 * Works with and without <ClientRouter />.
 *
 * Usage:
 *   <ThemeToggle />
 *   <ThemeToggle class="navbar-item" label="Switch color scheme" />
 */

interface Props {
  /** Accessible label for the button */
  label?: string;
  /** Bulma size modifier */
  size?: "small" | "medium" | "large";
  /** Extra classes on the button */
  class?: string;
  [key: string]: unknown;
}

const {
  label = "Toggle dark mode",
  size,
  class: className,
  ...rest
} = Astro.props;

const classes = ["button", size && `is-${size}`, className]
  .filter(Boolean)
  .join(" ");
---

<button
  type="button"
  class={classes}
  aria-label={label}
  aria-pressed="false"
  data-theme-toggle
  {...rest}
>
  <!-- Both icons live in one .icon span so the button's child structure never
       changes — Bulma gives :first-child and :last-child icons different
       margins, so swapping two sibling spans makes the icon jump. -->
  <span class="icon" aria-hidden="true">
    <svg
      class="theme-toggle-moon"
      width="1em"
      height="1em"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
    <svg
      class="theme-toggle-sun"
      width="1em"
      height="1em"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="12" cy="12" r="5"></circle>
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </svg>
  </span>
  <slot />
</button>

<style>
  .theme-toggle-sun {
    display: none;
  }
  :global([data-theme="dark"]) .theme-toggle-moon {
    display: none;
  }
  :global([data-theme="dark"]) .theme-toggle-sun {
    display: inline;
  }
</style>

<!-- Runs during parse, before the page paints, so the saved theme applies
     without a flash. Idempotent: safe with multiple toggles on a page. -->
<script is:inline>
  (function () {
    try {
      var theme =
        localStorage.getItem("theme") ||
        (window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light");
      document.documentElement.setAttribute("data-theme", theme);
    } catch (_e) {
      /* localStorage unavailable */
    }
  })();
</script>

<script>
  const THEME_KEY = "theme";

  function applyTheme(theme: string) {
    document.documentElement.setAttribute("data-theme", theme);
    document
      .querySelectorAll<HTMLElement>("[data-theme-toggle]")
      .forEach((btn) => {
        btn.setAttribute("aria-pressed", String(theme === "dark"));
      });
  }

  function bindToggles() {
    const current = document.documentElement.getAttribute("data-theme");
    document
      .querySelectorAll<HTMLElement>("[data-theme-toggle]")
      .forEach((btn) => {
        btn.setAttribute("aria-pressed", String(current === "dark"));
        if (btn.dataset.themeToggleBound) return;
        btn.dataset.themeToggleBound = "true";
        btn.addEventListener("click", () => {
          const theme =
            document.documentElement.getAttribute("data-theme") === "dark"
              ? "light"
              : "dark";
          applyTheme(theme);
          localStorage.setItem(THEME_KEY, theme);
        });
      });
  }

  // Bind now for plain MPA pages — astro:page-load only fires when
  // <ClientRouter /> is present — and rebind after every router navigation.
  bindToggles();
  document.addEventListener("astro:page-load", bindToggles);

  // The router swaps in the incoming document's <html> attributes, which never
  // include data-theme, so carry the current theme across navigations.
  document.addEventListener("astro:before-swap", (event) => {
    const theme = document.documentElement.getAttribute("data-theme");
    const newDocument = (event as Event & { newDocument: Document })
      .newDocument;
    if (theme) newDocument.documentElement.setAttribute("data-theme", theme);
  });

  // Follow live system preference changes until the user has chosen a theme.
  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", (event) => {
      if (!localStorage.getItem(THEME_KEY)) {
        applyTheme(event.matches ? "dark" : "light");
      }
    });
</script>
