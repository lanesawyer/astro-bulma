{
  "name": "astro-bulma",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.0.3",
  "description": "Astro component library wrapping Bulma CSS",
  "keywords": [
    "astro",
    "bulma",
    "component-library",
    "astro-component"
  ],
  "license": "(GPL-3.0-only OR MIT)",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "docs:dev": "astro --root docs dev",
    "docs:build": "astro --root docs build",
    "docs:preview": "astro --root docs preview",
    "check": "astro check",
    "check:docs": "astro --root docs check",
    "lint": "oxlint src --deny-warnings",
    "fmt": "oxlint src --fix && prettier --write \"src/**/*.astro\"",
    "fmt:check": "prettier --check \"src/**/*.astro\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "astro": ">=5.0.0"
  },
  "dependencies": {
    "bulma": "1.0.4"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/starlight": "0.38.4",
    "@fortawesome/fontawesome-free": "7.2.0",
    "@vitest/coverage-istanbul": "4.1.5",
    "astro": "6.2.1",
    "oxlint": "1.62.0",
    "postcss": "8.5.13",
    "postcss-selector-parser": "7.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "11.0.3"
  },
  "volta": {
    "node": "24.13.1",
    "pnpm": "11.0.3"
  }
}
