---
// Wraps a live component example in a styled preview box
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<!-- `not-content` opts out of Starlight's markdown flow styles (e.g. the
     adjacent-sibling margin rule) which otherwise leak into Bulma layouts. -->
<div class:list={["preview", "not-content", className]}>
  <slot />
</div>
